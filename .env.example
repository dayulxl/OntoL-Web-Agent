# ============================================================
# LangGraph Cluster — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值

# --- 应用 ---
DEBUG=false
CORS_ORIGINS=["*"]

# --- LLM 模型 ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# DeepSeek / 自定义 OpenAI 兼容 API
# CUSTOM_LLM_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_LLM_API_KEY=sk-...

# --- 知识图谱推理机 ---
KG_SERVER_URL=http://192.168.56.1:8085

# --- Neo4j ---
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# --- 日志 ---
LOG_LEVEL=INFO
